version: "3.9"

services:
  attendance:
    build: .
    container_name: church-attendance
    restart: unless-stopped
    ports:
      - "80:8000"
    volumes:
      - ./data:/data          # SQLite database — persists between restarts
      - ./config:/config      # Drop your seats.svg here
    environment:
      - PYTHONUNBUFFERED=1
    network_mode: bridge      # Must reach camera at 10.10.140.140
    extra_hosts:
      - "host.docker.internal:host-gateway"
