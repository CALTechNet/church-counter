# ─── Camera ───────────────────────────────────────────────
CAMERA_IP=10.10.140.140
CAMERA_RTSP_URL=rtsp://10.10.140.140:554/1
CAMERA_PTZ_BASE=http://10.10.140.140/cgi-bin/ptzctrl.cgi
CAMERA_USER=admin
CAMERA_PASS=admin

# ─── Scan Settings ────────────────────────────────────────
# How long to pan before capturing a frame (seconds)
SCAN_FRAME_INTERVAL=1.5
# Pan speed during auto-sweep (1-24)
SCAN_PAN_SPEED=6
# Tilt speed (1-20)
SCAN_TILT_SPEED=6
# Total sweep time per level (seconds) - tune to match your room width
SCAN_SWEEP_DURATION=12
# How long to wait for camera to settle before capturing (seconds)
SCAN_SETTLE_TIME=0.8
# Number of vertical levels (1=main floor only, 2=main+balcony)
SCAN_LEVELS=2
# Tilt up duration to reach balcony level (seconds)
SCAN_TILT_UP_DURATION=2.5
# Home position tilt down after scan (seconds)
SCAN_RETURN_TILT_DOWN=2.5

# ─── Scheduler ────────────────────────────────────────────
TIMEZONE=America/Chicago
# Format: HH:MM  (24-hour)
SCHEDULE_SUNDAY_AM=09:45
SCHEDULE_SUNDAY_PM=11:30
SCHEDULE_WEDNESDAY=19:30

# ─── AI Detection ─────────────────────────────────────────
YOLO_MODEL=yolo11x.pt
YOLO_CONFIDENCE=0.25
# Minimum pixels a detection must be to count (filters out tiny false positives)
YOLO_MIN_SIZE=5

# ─── Database ─────────────────────────────────────────────
DB_PATH=/data/attendance.db

# ─── App ──────────────────────────────────────────────────
DATA_DIR=/data
STATIC_DIR=/app/static
