# ─────────────────────────────────────────────────────────────────────────────
# Church Attendance Counter — Environment Configuration
# Copy to .env (or set directly in docker-compose.yml) and adjust as needed.
# All settings are optional — sensible defaults are used when not set.
# Settings saved via the web UI are stored in the database and take precedence
# over these values after first save.
# ─────────────────────────────────────────────────────────────────────────────

# ── Church identity ──────────────────────────────────────────────────────────
# Displayed in the web UI header.  Change to your congregation's name.
CHURCH_NAME=My Church

# ── Timezone ─────────────────────────────────────────────────────────────────
# Used for scheduled scans and log timestamps.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Chicago

# ── Persistent data paths ────────────────────────────────────────────────────
# These must match the volume mount targets in docker-compose.yml.
DATA_DIR=/opt/church-counter/data          # SQLite database + scan images
CONFIG_DIR=/opt/church-counter/config      # Custom seats.svg seat-map
MODELS_DIR=/opt/church-counter/models      # Optional YOLO / OpenVINO weights

# ── Camera ───────────────────────────────────────────────────────────────────
# camera_type controls which camera driver is used.
# Supported now:  visca_ptz  (PTZ Optics / Sony VISCA-over-TCP)
# Planned future: rtsp_static, hikvision, dahua, onvif
CAMERA_TYPE=visca_ptz

# IP address of the PTZ camera on your network
CAMERA_IP=192.168.1.100

# HTTP Basic auth credentials for the camera web interface / VISCA login
CAMERA_USER=admin
CAMERA_PASS=admin

# RTSP stream URL — leave blank to auto-derive from CAMERA_IP
# RTSP_URL=rtsp://192.168.1.100:554/1

# ── AI model ─────────────────────────────────────────────────────────────────
# Path or Ultralytics model name.  Set to an OpenVINO export for faster CPUs:
#   /opt/church-counter/models/yolo11x_openvino_model
# YOLO_MODEL=yolo11x.pt
